# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/focusfeed
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5433/focusfeed
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=focusfeed

# Auth
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# MiniMax AI
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_GROUP_ID=

# S3-compatible storage
S3_ENDPOINT_URL=http://localhost:9002
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=focusfeed-uploads
S3_REGION=us-east-1

# Backend
BACKEND_CORS_ORIGINS=["http://localhost:8081","http://localhost:19006"]
