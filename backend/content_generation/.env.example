# --- LLM Backend (for topic segmentation + script generation) ---
# Options: featherless | minimax | openai
LLM_BACKEND=featherless

# Featherless.ai (recommended — best open models, free tier, OpenAI-compatible)
FEATHERLESS_API_KEY=your-featherless-api-key
FEATHERLESS_MODEL=Qwen/Qwen3-72B

# MiniMax (used for AI video generation + TTS voiceover in slides-only mode)
MINIMAX_API_KEY=your-minimax-api-key

# TTS settings (for slides-only mode)
# MINIMAX_TTS_MODEL=speech-2.0-hd
# MINIMAX_VOICE_ID=male-qn-qingse

# Set to true for offline dev with mock responses
# MINIMAX_MOCK=true

# --- AWS Transcribe (for fast initial video transcription) ---
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY via `aws configure` or set here
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# --- Alternative LLM backends ---
# To use OpenAI or any OpenAI-compatible API (Groq, Together, etc.):
# LLM_BACKEND=openai
# OPENAI_API_KEY=your-key
# OPENAI_BASE_URL=https://api.openai.com   # or https://api.groq.com/openai for Groq
# OPENAI_MODEL=gpt-4o-mini
